PORT=8088
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ALLOWED_ORIGIN=*
# Shared with host when backend runs in Docker (see docker-compose volume mount).
VERIFY_WORK_DIR=/tmp/soroban-verify
# SQLite path for persisted verification lookups (GET /v1/...).
DATABASE_URL=/var/lib/csv/verifications.db
VERIFIER_ID=csv-stellar
DEFAULT_NETWORK=testnet
